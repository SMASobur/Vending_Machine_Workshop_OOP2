classDiagram
    class Product {
        -int id
        -String name
        -int price
        -String quantity
        +Product(int id, String name, int price, String quantity)
        +getId() int
        +getName() String
        +getPrice() int
        +getQuantity() String
        +setName(String name) void
        +setPrice(int price) void
        +setQuantity(String quantity) void
        +reduceQuantity() void
        +getDescription() String*
        +toString() String
    }

    class Beverage {
        -int milliliters
        +Beverage(int id, String name, int price, int quantity, int milliliters)
        +getDescription() String
    }

    class Fruit {
        -boolean isOrganic
        +Fruit(int id, String name, int price, int quantity, boolean isOrganic)
        +getDescription() String
    }

    class Snack {
        -boolean isVegan
        +Snack(int id, String name, int price, int quantity, boolean isVegan)
        +getDescription() String
    }
    class IVendingMachine {
        <<interface>>
        +insertCoin(int coin) void
        +getBalance() int
        +purchaseProduct(int productId) Product
        +returnChange() int
        +getProducts() List~Product~
    }

    class VendingMachineImpl {
        -int balance
        -List~Product~ products
        -int[] validCoins
        +VendingMachineImpl(List~Product~ initialProducts)
        +insertCoin(int coin) void
        +getBalance() int
        +purchaseProduct(int productId) Product
        +returnChange() int
        +getProducts() List~Product~
        -isValidCoin(int coin) boolean
    }

    class GetUserChoice {
        +getInt(Scanner scanner, String prompt) int
    }

    class MenuHandler {
        -Scanner scanner
        +MenuHandler(Scanner scanner)
        +displayMainMenu() void
    }

    class Main {
        -Scanner scanner
        -MenuHandler menuHandler
        -IVendingMachine machine
        +main(String[] args) void
        -setupVendingMachine() void
        -displayProducts() void
        -handleInsertCoin() void
        -handlePurchase() void
    }

    Product <|-- Beverage : extends
    Product <|-- Fruit : extends
    Product <|-- Snack : extends
    IVendingMachine <|.. VendingMachineImpl : implements
    VendingMachineImpl --> Product : contains
    MenuHandler --> GetUserChoice : uses
    Main --> MenuHandler : creates
    Main --> GetUserChoice : uses
    Main --> IVendingMachine : uses
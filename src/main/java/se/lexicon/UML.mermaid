classDiagram
    class IVendingMachine {
        <<interface>>
        + insertCoin(int coin) void
        + getBalance() int
        + purchaseProduct(int productId) Product
        + returnChange() int
        + getProducts() List~Product~
    }

    class Product {
        <<abstract>>
        # int id
        # String name
        # int price
        # int quantity
        + Product(int, String, int, int)
        + getId() int
        + getName() String
        + getPrice() int
        + getQuantity() int
        + reduceQuantity() void
        + getDescription() String*
    }

    class Beverage {
        - int milliliters
        + Beverage(int, String, int, int, int)
        + getDescription() String
    }

    class Fruit {
        - boolean isOrganic
        + Fruit(int, String, int, int, boolean)
        + getDescription() String
    }

    class Snack {
        - boolean isVegan
        + Snack(int, String, int, int, boolean)
        + getDescription() String
    }

    class VendingMachineImpl {
        - int balance
        - List~Product~ products
        - int[] validCoins
        + VendingMachineImpl(List~Product~)
        + insertCoin(int) void
        + getBalance() int
        + purchaseProduct(int) Product
        + returnChange() int
        + getProducts() List~Product~
    }

    class Main {
        - Scanner scanner
        - MenuHandler menuHandler
        - IVendingMachine machine
        + main(String[]) void
    }

    class MenuHandler {
        - Scanner scanner
        + MenuHandler(Scanner)
        + displayMainMenu() void
    }

    class GetUserChoice {
        + getInt(Scanner, String) int
    }

    Product <|-- Beverage
    Product <|-- Fruit
    Product <|-- Snack
    IVendingMachine <|.. VendingMachineImpl
    VendingMachineImpl --> Product : contains
    Main --> IVendingMachine : uses
    Main --> MenuHandler : creates
    Main --> GetUserChoice : uses
    MenuHandler --> Scanner : uses